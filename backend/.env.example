# Copy to .env for local development. Never commit .env.

# Server
APP_HOST=0.0.0.0
APP_PORT=8080

# Local compose stack (see infra/docker-compose.yml — PG is on 55432
# because 5432 is occupied on the dev host)
DATABASE_URL=postgres://urbansatna:urbansatna@localhost:55432/urbansatna
REDIS_URL=redis://localhost:6379

# Apply embedded migrations on startup (true for dev, false in prod)
RUN_MIGRATIONS=true

# Logging: json (prod) | pretty (dev)
LOG_FORMAT=pretty
RUST_LOG=urbansatna_api=debug,tower_http=info,sqlx=warn

# Auth
JWT_SECRET=change-me                   # required; long random string in prod
ACCESS_TTL_SECS=900                    # access-token lifetime
REFRESH_TTL_DAYS=30                    # refresh-token lifetime (sliding)
ADMIN_PHONES=                          # CSV of phones auto-granted admin on login
DEV_RETURN_OTP=false                   # true = OTP in API response (dev ONLY, no SMS yet)
